{
  "name": "dual-mind",
  "version": "1.0.0",
  "description": "Dual Mind - Browser-Based Multiplayer Game Suite with ML-Driven Performance Monitoring",
  "main": "src/js/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write src/**/*.js"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.2.0",
    "terser": "^5.46.0",
    "vite": "^5.0.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "moduleFileExtensions": [
      "js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/js/main.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    }
  },
  "author": "",
  "license": "MIT",
  "keywords": [
    "games",
    "multiplayer",
    "machine-learning",
    "performance-tracking",
    "iq-monitoring"
  ],
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "animejs": "^3.2.2",
    "chart.js": "^4.5.1",
    "framer-motion": "^12.34.3",
    "gsap": "^3.14.2",
    "lenis": "^1.3.17",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
